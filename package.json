{
  "name": "gigahrush",
  "private": true,
  "license": "SEE LICENSE IN LICENSE.md",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test:unit": "tsx --test tests/*.test.ts",
    "test:generation": "GIGAHRUSH_GENERATION_MATRIX=1 tsx --test tests/*.test.ts",
    "build": "vite build",
    "build:size": "node scripts/build-size-report.mjs",
    "itch:build": "node scripts/build-itch.mjs",
    "itch:verify": "node scripts/verify-itch-pack.mjs",
    "artifacts:verify": "node scripts/verify-artifacts.mjs",
    "preview": "vite preview",
    "smoke": "node scripts/smoke-playability.mjs",
    "content:audit": "node scripts/content-audit.mjs",
    "check:readonly": "npm run typecheck && npm run test:unit && npm run content:audit",
    "check:browser": "npm run build && npm run smoke",
    "check:release": "npm run check:readonly && npm run itch:build && npm run artifacts:verify && npm run itch:verify",
    "cf:setup": "node scripts/cloudflare-net-setup.mjs",
    "cf:schema": "node scripts/cloudflare-net-setup.mjs --schema-only",
    "cf:dev": "npm run build && wrangler dev",
    "cf:deploy": "npm run build && wrangler deploy",
    "check": "npm run typecheck && npm run test:unit && npm run content:audit && npm run build",
    "check:full": "npm run check && npm run smoke"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.22.1",
    "typescript": "5.9.3",
    "vite": "^7.3.3",
    "vite-plugin-singlefile": "2.3.0",
    "wrangler": "^4.92.0"
  }
}
